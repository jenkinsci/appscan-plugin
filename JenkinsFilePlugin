pipeline {
    // Label of my Windows controller node
    // For actual build, ensure this labeled node is online and available.
    // For testing, you can comment this and use: agent any
    agent { label 'jenkinsAgent' }
    //agent any

    tools {
        jdk 'TOOLS-JDK-17'
        maven 'Maven 3.6.1'     //My Windows controller has apache-maven-3.9.15 installed
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: "${params.BRANCH_TO_BUILD}" ?: 'master',
                    url: 'https://github.com/jenkinsci/appscan-plugin.git'
            }
        }

        stage('Build Plugin') {
            steps {
                script {
                    if (isUnix()) {
                        sh 'mvn -B clean install'
                    } else {
                        bat 'mvn -B clean install'
                    }
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: '**/target/*.hpi, **/target/*.jpi', fingerprint: true
            }
        }
    }

    post {
        success {
            echo 'Plugin build successful!'
        }
        failure {
            echo 'Build failed. Check logs.'
        }
    }
}
