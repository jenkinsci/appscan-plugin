pipeline {
    // For actual build, ensure this labeled node is online and available.
    // For testing, you can comment this and use: agent any
    agent { label 'pluginJenkins' }

    tools {
        jdk 'TOOLS-JDK-17'
        maven 'Maven 3.6.1'
    }

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))  //Keep only the latest 10 build records for this job.
        skipDefaultCheckout(true)     //Skip automatic checkout; the repository is checked out later in the pipeline.
    }

    environment {
        REPO_URL = 'https://github.com/jenkinsci/appscan-plugin.git'
        REPO_NAME = 'jenkinsci/appscan-plugin'
        GITHUB_CREDENTIALS_ID = 'GithubAccess'
        PIPELINE_VERSION = '1.1.0'
    }

    stages {
        stage('Validate Parameters') {
            steps {
                script {
                    echo "Pipeline Version: ${env.PIPELINE_VERSION}"
                    // Federal jobs require config.xml-defined parameters.
                    // This Jenkinsfile must not define a parameters block.

                    env.GIT_BRANCH_NAME = ((params?.BRANCH_TO_BUILD ?: env.BRANCH_TO_BUILD ?: 'master') as String).trim()

                    def isFederal = env.GLOBAL_JENKINS_FEDERAL?.toBoolean()

                    if (isFederal) {
                        if (env.GIT_BRANCH_NAME.equalsIgnoreCase('main') || env.GIT_BRANCH_NAME.equalsIgnoreCase('master')) {
                            error('Federal AP builds cannot be run against main/master. ' + 'Request a build from a non-main branch.')
                        }
                        if (!currentBuild.getBuildCauses('hudson.model.Cause$UserIdCause')) {
                            error('Federal AP supports on-demand builds only. ' + 'Start the build manually from an approved Jira request.')
                        }
                    }

                    echo "GLOBAL_JENKINS_FEDERAL=${env.GLOBAL_JENKINS_FEDERAL ?: 'false'}"
                    echo "Branch=${env.GIT_BRANCH_NAME}"
                }
            }
        }

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                script {
                    def retryCount = 0
                    retry(3) {
                        if (retryCount > 0) {
                            echo "Retry #${retryCount} in 30 seconds..."
                            sleep time: 30, unit: 'SECONDS'
                        }
                        retryCount++
                        git branch: env.GIT_BRANCH_NAME,
                            credentialsId: env.GITHUB_CREDENTIALS_ID,
                            url: env.REPO_URL
                    }
                }
            }
        }


        stage('Build Plugin') {
            steps {
                script {
                    sh('mvn -B clean verify')
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: '**/target/*.hpi, BUILDINFO.json, CHANGEINFO.json', allowEmptyArchive: false , fingerprint: true
            }
        }
    }

    post {
        success {
            echo "Plugin build successful! Build #${env.BUILD_NUMBER}"
        }
        failure {
            echo "Build #${env.BUILD_NUMBER} failed. Check logs: ${env.BUILD_URL}console"
        }
        always {
            cleanWs()
        }
    }
}
